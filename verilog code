`timescale 1ns / 1ps

module mux_4to1( I0,I1,I2,I3,S0,S1,Y);
input I0,I1,I2,I3,S0,S1;
output Y;
wire w1,w2,w3,w4,S0_bar,S1_bar;
//instatntiation;

not a1(S1_bar,S1);
not a2(S0_bar,S0);

and g1(w1,I0,S1_bar,S0_bar);
and g2(w2,I1,S1,S0_bar);
and g3(w3,I2,S1_bar,S0);
and g4(w1,I3,S1,S0);
or g5(Y,w1,w2,w3,w4);
endmodule
